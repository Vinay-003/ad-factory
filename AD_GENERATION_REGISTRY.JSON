    {
      "id": "entry_001",
      "timestamp": "2026-04-14T10:45:48Z",
      "format": "HERO",
      "persona_number": 21,
      "persona_name": "Beginner Who Hates Complex Plans",
      "headline_angle": "sacrifice_reduction",
      "headline_en": "Weight loss can start without a complicated plan.",
      "headline_hi": "वजन घटाना शुरू हो सकता है, बिना मुश्किल प्लान के।",
      "support_line_en": "Ayurvedic hunger and digestion support for a lighter 15-day start.*",
      "support_line_hi": "आयुर्वेदिक सपोर्ट जो भूख और पाचन को संभालकर 15 दिन की हल्की शुरुआत दे।*",
      "cta_en": "Start Simple",
      "cta_hi": "आसान शुरुआत करें",
      "disclaimer_en": "*Average loss is 3-5 kg in 15 days. Results vary by body, routine, and adherence.",
      "disclaimer_hi": "*औसतन 15 दिनों में 3-5 किलो तक कमी देखी गई है। परिणाम शरीर, दिनचर्या और पालन पर निर्भर करते हैं।",
      "caption_en": "Start with a simple Ayurvedic routine that helps manage hunger, supports digestion, and aims for visible 15-day progress without crash diets.",
      "caption_hi": "एक आसान आयुर्वेदिक रूटीन से शुरुआत करें जो भूख को संभालने, पाचन को सपोर्ट करने और बिना crash diet के 15 दिन की दिखने वाली प्रगति की दिशा में मदद करे।",
      "bullets_en": [],
      "bullets_hi": [],
      "background_slot": "BG-001",
      "background_name": "Warm studio cream",
      "background_source": "catalog",
      "fresh_background_signature": null,
      "language": "BOTH",
      "output_quality": "approved",
      "notes": "Default starter batch HERO prompt generated in EN and HI."
    },
    {
      "id": "entry_002",
      "timestamp": "2026-04-14T10:45:48Z",
      "format": "BA",
      "persona_number": 12,
      "persona_name": "Late-Night Eater",
      "headline_angle": "time",
      "headline_en": "When late-night hunger settles down, progress starts showing.*",
      "headline_hi": "जब रात की भूख शांत होती है, तब बदलाव दिखना शुरू होता है।*",
      "support_line_en": "Three-part routine moves from fullness support to calmer nighttime digestion.",
      "support_line_hi": "तीन-भाग वाला रूटीन सुबह की fullness support से रात के शांत पाचन सपोर्ट तक साथ देता है।",
      "cta_en": "See Your Shift",
      "cta_hi": "अपना बदलाव देखें",
      "disclaimer_en": "*Visible progress varies. Average users may lose 3-5 kg in 15 days with routine compliance.",
      "disclaimer_hi": "*दिखने वाले परिणाम अलग हो सकते हैं। औसतन 15 दिनों में 3-5 किलो कमी रूटीन पालन पर निर्भर है।",
      "caption_en": "For people who snack hardest at night, this Ayurvedic routine supports appetite control in the morning and digestion at bedtime without punishing restrictions.",
      "caption_hi": "जो लोग रात में सबसे ज्यादा स्नैक करते हैं, उनके लिए यह आयुर्वेदिक रूटीन सुबह appetite control और सोने से पहले digestion support देता है, बिना कठोर रोक-टोक के।",
      "bullets_en": [
        "Morning OK Liquid supports fullness for longer.",
        "Night tablet and powder support digestion before sleep.",
        "No crash diet. No punishing workout routine."
      ],
      "bullets_hi": [
        "सुबह का OK Liquid लंबे समय तक भरा हुआ महसूस कराने में सहायक है।",
        "रात का टैबलेट और पाउडर सोने से पहले पाचन को सपोर्ट करते हैं।",
        "न crash diet, न बहुत कठिन workout routine।"
      ],
      "background_slot": "BG-002",
      "background_name": "Morning kitchen wood",
      "background_source": "catalog",
      "fresh_background_signature": null,
      "language": "BOTH",
      "output_quality": "approved",
      "notes": "Default starter batch BA prompt generated in EN and HI."
    },
    {
      "id": "entry_003",
      "timestamp": "2026-04-14T10:45:48Z",
      "format": "TEST",
      "persona_number": 9,
      "persona_name": "Time-Starved Parent",
      "headline_angle": "proof",
      "headline_en": "\"I needed something simple enough for real life.\"",
      "headline_hi": "\"मुझे कुछ ऐसा चाहिए था जो सच में रोज़मर्रा की ज़िंदगी में फिट हो सके।\"",
      "support_line_en": "Hunger control in the morning. Digestion support at night.",
      "support_line_hi": "सुबह भूख नियंत्रण का सपोर्ट। रात में पाचन का सपोर्ट।",
      "cta_en": "Make Room For You",
      "cta_hi": "अपने लिए जगह बनाएं",
      "disclaimer_en": "*Supportive weight-loss results differ from person to person and depend on daily follow-through.",
      "disclaimer_hi": "*वजन घटाने में मिलने वाला सपोर्ट और परिणाम व्यक्ति व उसकी दिनचर्या के अनुसार अलग हो सकते हैं।",
      "caption_en": "Built for packed days, this trust-led creative leans on 70,000+ users, Dr. Arun Tyagi's Ayurvedic approach, and a simple daily rhythm people can actually follow.",
      "caption_hi": "व्यस्त दिनचर्या के लिए बना यह भरोसे-आधारित संदेश 70,000+ यूज़र्स, डॉ. अरुण त्यागी के आयुर्वेदिक दृष्टिकोण और ऐसे सरल रूटीन पर आधारित है जिसे लोग सच में निभा सकें।",
      "bullets_en": [],
      "bullets_hi": [],
      "background_slot": "BG-003",
      "background_name": "Home-office lamp",
      "background_source": "catalog",
      "fresh_background_signature": null,
      "language": "BOTH",
      "output_quality": "approved",
      "notes": "Default starter batch TEST prompt generated in EN and HI."
    },
    {
      "id": "entry_004",
      "timestamp": "2026-04-14T10:45:48Z",
      "format": "FEAT",
      "persona_number": 19,
      "persona_name": "Trust-First Buyer",
      "headline_angle": "mechanism",
      "headline_en": "What makes this kit easier to trust?",
      "headline_hi": "इस किट पर भरोसा करना आसान क्यों लगे?",
      "support_line_en": "A doctor-backed Ayurvedic structure explains what each part of the kit does.",
      "support_line_hi": "डॉक्टर-समर्थित आयुर्वेदिक संरचना साफ बताती है कि किट का हर भाग क्या करता है।",
      "cta_en": "Review The Kit",
      "cta_hi": "किट को समझें",
      "disclaimer_en": "*This is Ayurvedic support, not a medical cure. Progress differs by body response and consistency.",
      "disclaimer_hi": "*यह आयुर्वेदिक सपोर्ट है, कोई चिकित्सीय इलाज नहीं। प्रगति शरीर की प्रतिक्रिया और नियमितता पर निर्भर करती है।",
      "caption_en": "Trust-first buyers get a clearer view of the method here: morning hunger support, nighttime digestion support, and a structured Ayurvedic routine with guidance.",
      "caption_hi": "भरोसा पहले चाहने वाले खरीदार यहां तरीके को अधिक साफ समझते हैं: सुबह भूख का सपोर्ट, रात में पाचन का सपोर्ट, और मार्गदर्शन के साथ संरचित आयुर्वेदिक रूटीन।",
      "bullets_en": [
        "Morning liquid helps manage hunger and cravings.",
        "Night powder and tablet support digestion and metabolism.",
        "Ayurvedic routine with 70,000+ users and support guidance."
      ],
      "bullets_hi": [
        "सुबह का liquid भूख और cravings को संभालने में सहायक है।",
        "रात का powder और tablet पाचन और metabolism को सपोर्ट करते हैं।",
        "आयुर्वेदिक रूटीन, 70,000+ यूज़र्स और सपोर्ट गाइडेंस के साथ।"
      ],
